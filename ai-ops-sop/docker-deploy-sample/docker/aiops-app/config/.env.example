# ── Upstream services (use Docker/K8s service names) ─────────────────────────
FASTAPI_BASE_URL=http://aiops-java-api:8080
AGENT_BASE_URL=http://aiops-python-sidecar:8080
ONTOLOGY_BASE_URL=http://ontology-simulator:8080

# ── Service token (Authorization: Bearer sent to upstream) ───────────────────
INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_API_TOKEN

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=CHANGE_ME_32_CHARS_MIN

# ── OIDC upsert bridge secret (must match java-backend AIOPS_OIDC_UPSERT_SECRET) ──
AIOPS_OIDC_UPSERT_SECRET=CHANGE_ME_UPSERT_SECRET

# ── Enforce auth (set to 1 in production) ────────────────────────────────────
AIOPS_AUTH_REQUIRED=1

# ── Keycloak OIDC provider ────────────────────────────────────────────────────
OIDC_KEYCLOAK_CLIENT_ID=aiops
OIDC_KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_SECRET
OIDC_KEYCLOAK_ISSUER=https://keycloak.your-domain.com/realms/aiops

# ── Azure AD provider (optional — leave blank to disable) ────────────────────
OIDC_AZURE_CLIENT_ID=
OIDC_AZURE_CLIENT_SECRET=
OIDC_AZURE_TENANT_ID=

# ── Google provider (optional) ────────────────────────────────────────────────
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=

# ── Okta provider (optional) ─────────────────────────────────────────────────
OIDC_OKTA_CLIENT_ID=
OIDC_OKTA_CLIENT_SECRET=
OIDC_OKTA_ISSUER=

# ── LLM key for frontend-side agent (optional) ───────────────────────────────
ANTHROPIC_API_KEY=

# ── Next.js runtime ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
HOSTNAME=0.0.0.0
