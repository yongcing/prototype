# ── Spring profile ────────────────────────────────────────────────────────────
AIOPS_PROFILE=prod
AIOPS_JAVA_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/aiops
DB_USER=aiops
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Local JWT (used only when AUTH_MODE=local) ────────────────────────────────
JWT_SECRET=CHANGE_ME_32_CHARS_OR_MORE_____________
JWT_EXPIRY_MS=86400000
JWT_ISSUER=aiops-platform

# ── Auth mode: "oidc" for production, "local" for dev without IdP ────────────
AUTH_MODE=oidc

# ── OIDC / Keycloak (active when AUTH_MODE=oidc) ─────────────────────────────
OIDC_ISSUER=https://keycloak.your-domain.com/realms/aiops
OIDC_CLIENT_ID=aiops-backend
OIDC_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_BACKEND_SECRET
# Role claim name in JWT — Keycloak default is "roles"; Azure AD may use "groups"
OIDC_ROLE_CLAIM=roles
# Keycloak JWK endpoint — used for RS256 token validation
# Pattern: <OIDC_ISSUER>/protocol/openid-connect/certs
OIDC_JWK_URI=https://keycloak.your-domain.com/realms/aiops/protocol/openid-connect/certs

# ── OIDC upsert bridge secret (must match aiops-app AIOPS_OIDC_UPSERT_SECRET) ─
AIOPS_OIDC_UPSERT_SECRET=CHANGE_ME_UPSERT_SECRET

# ── Legacy shared-secret (Frontend cutover compat — leave empty if not needed) ─
AIOPS_SHARED_SECRET_TOKEN=

# ── Python sidecar (outbound calls from java-backend) ────────────────────────
PYTHON_SIDECAR_URL=http://aiops-python-sidecar:8080
PYTHON_SIDECAR_TOKEN=CHANGE_ME_SIDECAR_TOKEN

# ── Internal service-to-service token (sidecar → java, scheduler → java) ─────
JAVA_INTERNAL_TOKEN=CHANGE_ME_INTERNAL_TOKEN
# Comma-separated CIDRs allowed to call /internal/* (use pod CIDR in K8s)
JAVA_INTERNAL_ALLOWED_IPS=127.0.0.1,::1,10.0.0.0/8

# ── Scheduler ─────────────────────────────────────────────────────────────────
AIOPS_SCHEDULER_BASE_URL=http://aiops-java-scheduler:8080
AIOPS_SCHEDULER_INTERNAL_TOKEN=CHANGE_ME_SCHEDULER_TOKEN

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com
