# ── Spring profile ────────────────────────────────────────────────────────────
AIOPS_PROFILE=prod
AIOPS_SCHEDULER_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/aiops
DB_USER=aiops
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Internal token (must match java-backend AIOPS_SCHEDULER_INTERNAL_TOKEN) ───
AIOPS_SCHEDULER_INTERNAL_TOKEN=CHANGE_ME_SCHEDULER_TOKEN

# ── Python sidecar ────────────────────────────────────────────────────────────
PYTHON_SIDECAR_URL=http://aiops-python-sidecar:8080
# Must match python-sidecar SERVICE_TOKEN
PYTHON_SIDECAR_TOKEN=CHANGE_ME_SIDECAR_TOKEN

# ── Ontology simulator ────────────────────────────────────────────────────────
ONTOLOGY_SIM_URL=http://ontology-simulator:8080

# ── Audit log retention ───────────────────────────────────────────────────────
AIOPS_AUDIT_RETENTION_DAYS=90

# ── Redis distributed lock (fail-open if Redis unavailable) ──────────────────
REDIS_HOST=redis
REDIS_PORT=6379
AIOPS_LOCK_NAMESPACE=aiops:lock
AIOPS_LOCK_FAIL_OPEN=true
