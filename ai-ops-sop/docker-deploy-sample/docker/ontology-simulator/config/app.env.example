# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=semiconductor_sim

# ── Simulation scale ──────────────────────────────────────────────────────────
TOTAL_TOOLS=10
TOTAL_STEPS=20
TOTAL_RECIPES=20
CHAMBERS_PER_TOOL=4
MONITOR_LOT_EVERY=20

# ── SPC control limits ────────────────────────────────────────────────────────
SPC_SD_PRODUCTION=1.5
SPC_SD_MONITOR=2.0

# ── Lot pacer ─────────────────────────────────────────────────────────────────
ACTIVE_LOT_TARGET=20
LOT_BATCH_SIZE=10
PACER_INTERVAL_SEC=10

# ── Process timing (seconds) ──────────────────────────────────────────────────
HEARTBEAT_MIN=5
HEARTBEAT_MAX=10
PROCESSING_MIN=480
PROCESSING_MAX=600
HOLD_PROBABILITY=0.02
HOLD_TIMEOUT_SEC=300

# ── Physics / fault injection ─────────────────────────────────────────────────
APC_DRIFT_RATIO=0.05
OOC_PROBABILITY=0.07

# ── Manual override frequency (edits per 24h) ────────────────────────────────
MANUAL_OVERRIDE_MIN=1
MANUAL_OVERRIDE_MAX=2
