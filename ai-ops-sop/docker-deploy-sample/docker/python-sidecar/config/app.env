# ── Service token (callers must send X-Service-Token: <value>) ────────────────
SERVICE_TOKEN=aiops_sidecar_token_2024

# ── Port ──────────────────────────────────────────────────────────────────────
SIDECAR_PORT=8080

# ── IP allowlist for callers (comma-separated CIDRs; 0.0.0.0/0 = allow all) ──
ALLOWED_CALLERS=

# ── Java backend reverse-call ─────────────────────────────────────────────────
JAVA_API_URL=http://aiops-java-api:8080
# Must match java-backend JAVA_INTERNAL_TOKEN
JAVA_INTERNAL_TOKEN=aiops_internal_token_2024
JAVA_TIMEOUT_SEC=30

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8096

# ── Background tasks (0=disabled, 1=enabled) ─────────────────────────────────
EVENT_POLLER_ENABLED=0
NATS_SUBSCRIBER_ENABLED=0

# ── Optional: event poller (only if EVENT_POLLER_ENABLED=1) ──────────────────
# POLLER_SOURCE_URL=http://ontology-simulator:8080/events
# POLLER_INTERVAL_SEC=5
# POLLER_SERVICE_USER_ID=1
# POLLER_SERVICE_ROLES=IT_ADMIN

# ── Optional: NATS (only if NATS_SUBSCRIBER_ENABLED=1) ───────────────────────
# NATS_URL=nats://nats:4222

# ── Optional: Mem0 semantic memory ───────────────────────────────────────────
MEM0_API_KEY=
